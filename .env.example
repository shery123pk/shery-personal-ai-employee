# AI Employee Configuration
# Copy this file to .env and fill in values

# Vault path (defaults to AI_Employee_Vault/ in project root)
VAULT_PATH=AI_Employee_Vault

# Watcher polling interval in seconds (default: 1)
WATCHER_INTERVAL=1

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Gmail API (Phase 1 — Silver Tier)
# ---------------------------------------------------------------------------
# 1. Create a Google Cloud project: https://console.cloud.google.com/
# 2. Enable the Gmail API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download the credentials JSON and save as credentials.json

GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_POLL_INTERVAL_SEC=300
GMAIL_QUERY=is:unread is:important

# ---------------------------------------------------------------------------
# LinkedIn API (Phase 4 — Silver Tier)
# ---------------------------------------------------------------------------
# 1. Create a LinkedIn Developer App: https://www.linkedin.com/developers/
# 2. Request r_liteprofile and w_member_social permissions
# 3. Generate an access token

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_DRY_RUN=true

# ---------------------------------------------------------------------------
# Scheduler (Phase 6 — Silver Tier)
# ---------------------------------------------------------------------------

SCHEDULER_GMAIL_INTERVAL_MIN=5
SCHEDULER_PROCESS_INTERVAL_MIN=10
SCHEDULER_APPROVAL_INTERVAL_MIN=5
SCHEDULER_BRIEFING_HOUR=9

# ---------------------------------------------------------------------------
# OpenAI API (Gold Tier)
# ---------------------------------------------------------------------------
# 1. Get an API key from https://platform.openai.com/api-keys
# 2. Uses gpt-4o-mini for cost-efficient agent reasoning

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# ---------------------------------------------------------------------------
# Gold Tier Settings
# ---------------------------------------------------------------------------

# DEV_MODE: true = synthetic LLM responses (no API calls), false = live API
DEV_MODE=true

# Autonomous loop: max tasks to process per iteration
AUTONOMOUS_MAX_ITERATIONS=10
AUTONOMOUS_RETRY_LIMIT=3

# Finance watcher poll interval
FINANCE_POLL_INTERVAL_SEC=300

# Scheduler Gold additions
SCHEDULER_HEALTH_CHECK_MIN=2
SCHEDULER_AUTONOMOUS_INTERVAL_MIN=15
SCHEDULER_WEEKLY_BRIEFING_DAY=mon
